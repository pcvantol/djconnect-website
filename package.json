{
  "name": "djconnect-website",
  "version": "3.3.0",
  "private": true,
  "scripts": {
    "build": "npm run sitemap:build && npm run build:release",
    "sync:version": "node scripts/sync-site-version.mjs",
    "build:release": "node scripts/build-release.mjs",
    "deps:update": "node scripts/refresh-dependencies.mjs update",
    "deps:check": "node scripts/refresh-dependencies.mjs check",
    "sitemap:build": "node scripts/build-sitemap.mjs",
    "test": "npm run i18n:check && node --test",
    "test:coverage": "npm run i18n:check && c8 --reporter=cobertura --reports-dir=coverage node --test",
    "i18n:check": "node scripts/validate-i18n.mjs",
    "stats:check": "node scripts/check-stats.mjs",
    "screenshots": "SCREENSHOT_LANG=nl npx playwright test tests/screenshots.spec.mjs",
    "screenshots:all": "./scripts/capture-all-screenshots.sh",
    "screenshots:live": "SCREENSHOT_LANG=nl SCREENSHOT_BASE_URL=https://djconnect.dev npx playwright test tests/screenshots.spec.mjs",
    "test:smoke": "npx playwright test tests/smoke.spec.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "c8": "^10.1.3"
  },
  "license": "MIT"
}
